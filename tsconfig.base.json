{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@pacer/shared": ["packages/shared/src/index.ts"],
      "@pacer/shared/*": ["packages/shared/src/*"],
      "@pacer/core": ["packages/core/src/index.ts"],
      "@pacer/core/*": ["packages/core/src/*"],
      "@pacer/db": ["packages/db/src/index.ts"],
      "@pacer/db/*": ["packages/db/src/*"],
      "@pacer/llm": ["packages/llm/src/index.ts"],
      "@pacer/llm/*": ["packages/llm/src/*"],
      "@pacer/notifications": ["packages/notifications/src/index.ts"],
      "@pacer/notifications/*": ["packages/notifications/src/*"],
      "@pacer/reference-data": ["packages/reference-data/src/index.ts"],
      "@pacer/reference-data/*": ["packages/reference-data/src/*"]
    }
  }
}
